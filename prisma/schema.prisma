generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Team {
  id               String                  @id @default(uuid())
  name             String                  @unique
  logoUrl          String?
  kitUrl           String?
  createdAt        DateTime                @default(now())
  players          Player[]
  homeMatches      Match[]                 @relation("HomeTeamMatches")
  awayMatches      Match[]                 @relation("AwayTeamMatches")
  wonMatches       Match[]                 @relation("WinnerTeamMatches")
  signedFreeAgents FreeAgentRegistration[] @relation("SignedFreeAgents")
  wonGames         MatchGame[]             @relation("WinnerTeamGames")
  playerStats      MatchGamePlayerStat[]
}

model Player {
  id         String   @id @default(uuid())
  name       String
  riotName   String?
  riotTag    String?
  email      String?
  teamId     String?
  team       Team?    @relation(fields: [teamId], references: [id])
  elo        Int      @default(1000)
  winStreak  Int      @default(0)
  lossStreak Int      @default(0)
  createdAt  DateTime @default(now())

  gameStats MatchGamePlayerStat[]

  @@index([teamId])
  @@index([riotName, riotTag])
}

model FreeAgentRegistration {
  id               String   @id @default(uuid())
  playerName       String
  email            String
  riotName         String
  riotTag          String
  primaryRole      String
  secondaryRole    String?
  currentRank      String?
  notes            String?
  status           String   @default("pending")
  signedToTeamId   String?
  signedToTeamName String?
  submittedAt      DateTime @default(now())

  signedToTeam Team? @relation("SignedFreeAgents", fields: [signedToTeamId], references: [id])
}

model TeamRegistration {
  id           String   @id @default(uuid())
  teamName     String
  captainName  String
  captainEmail String
  players      Json
  status       String   @default("pending")
  submittedAt  DateTime @default(now())
}

model LeagueWireItem {
  id        String   @id @default(uuid())
  text      String
  href      String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id          String      @id @default(uuid())
  stage       MatchStage
  roundLabel  String?
  matchLabel  String?
  bestOf      Int
  scheduledAt DateTime?
  status      MatchStatus @default(SCHEDULED)

  homeTeamId   String
  awayTeamId   String
  winnerTeamId String?

  homeScore Int @default(0)
  awayScore Int @default(0)

  forfeitWinnerId String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  homeTeam   Team        @relation("HomeTeamMatches", fields: [homeTeamId], references: [id])
  awayTeam   Team        @relation("AwayTeamMatches", fields: [awayTeamId], references: [id])
  winnerTeam Team?       @relation("WinnerTeamMatches", fields: [winnerTeamId], references: [id])
  games      MatchGame[]

  @@index([stage])
  @@index([status])
  @@index([scheduledAt])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model MatchGame {
  id              String   @id @default(uuid())
  matchId         String
  gameNumber      Int
  winnerTeamId    String?
  durationSeconds Int?
  homeKills       Int?
  awayKills       Int?
  homeGold        Int?
  awayGold        Int?

  homeTowers      Int?
  awayTowers      Int?

  homeInhibitors  Int?
  awayInhibitors  Int?

  homeBarons      Int?
  awayBarons      Int?

  homeDrakes      Int?
  awayDrakes      Int?

  mvpName         String?
  notes           String?
  ocrRawJson      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  match       Match                @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winnerTeam  Team?                @relation("WinnerTeamGames", fields: [winnerTeamId], references: [id])
  playerStats MatchGamePlayerStat[]

  @@unique([matchId, gameNumber])
  @@index([matchId])
  @@index([winnerTeamId])
}

model MatchGamePlayerStat {
  id           String   @id @default(uuid())
  matchGameId  String
  playerId     String
  teamId       String?

  riotName     String?
  riotTag      String?

  kills        Int @default(0)
  deaths       Int @default(0)
  assists      Int @default(0)

  gold         Int?
  damage       Int?
  cs           Int?
  visionScore  Int?

  isWin        Boolean @default(false)
  isMVP        Boolean @default(false)
  isSVP        Boolean @default(false)

  lpChange     Int      @default(0)
  eloBefore    Int?
  eloAfter     Int?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  matchGame    MatchGame @relation(fields: [matchGameId], references: [id], onDelete: Cascade)
  player       Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team         Team?     @relation(fields: [teamId], references: [id])

  @@unique([matchGameId, playerId])
  @@index([matchGameId])
  @@index([playerId])
  @@index([teamId])
  @@index([isWin])
  @@index([isMVP])
}

enum MatchStage {
  REGULAR_SEASON
  PLAYOFFS
  SEMIFINALS
  FINALS
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
  FORFEIT
  POSTPONED
  CANCELLED
}