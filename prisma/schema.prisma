generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Team {
  id               String                  @id @default(uuid())
  name             String                  @unique
  logoUrl          String?
  kitUrl           String?
  createdAt        DateTime                @default(now())
  players          Player[]
  homeMatches      Match[]                 @relation("HomeTeamMatches")
  awayMatches      Match[]                 @relation("AwayTeamMatches")
  wonMatches       Match[]                 @relation("WinnerTeamMatches")
  signedFreeAgents FreeAgentRegistration[] @relation("SignedFreeAgents")
  wonGames         MatchGame[]             @relation("WinnerTeamGames")
}

model Player {
  id        String   @id @default(uuid())
  name      String
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
}

model FreeAgentRegistration {
  id               String   @id @default(uuid())
  playerName       String
  email            String
  riotName         String
  riotTag          String
  primaryRole      String
  secondaryRole    String?
  currentRank      String?
  notes            String?
  status           String   @default("pending")
  signedToTeamId   String?
  signedToTeamName String?
  submittedAt      DateTime @default(now())

  signedToTeam Team? @relation("SignedFreeAgents", fields: [signedToTeamId], references: [id])
}

model TeamRegistration {
  id           String   @id @default(uuid())
  teamName     String
  captainName  String
  captainEmail String
  players      Json
  status       String   @default("pending")
  submittedAt  DateTime @default(now())
}

model LeagueWireItem {
  id        String   @id @default(uuid())
  text      String
  href      String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id          String      @id @default(uuid())
  stage       MatchStage
  roundLabel  String?
  matchLabel  String?
  bestOf      Int
  scheduledAt DateTime?
  status      MatchStatus @default(SCHEDULED)

  homeTeamId   String
  awayTeamId   String
  winnerTeamId String?

  homeScore Int @default(0)
  awayScore Int @default(0)

  forfeitWinnerId String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  homeTeam   Team        @relation("HomeTeamMatches", fields: [homeTeamId], references: [id])
  awayTeam   Team        @relation("AwayTeamMatches", fields: [awayTeamId], references: [id])
  winnerTeam Team?       @relation("WinnerTeamMatches", fields: [winnerTeamId], references: [id])
  games      MatchGame[]

  @@index([stage])
  @@index([status])
  @@index([scheduledAt])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model MatchGame {
  id              String   @id @default(uuid())
  matchId         String
  gameNumber      Int
  winnerTeamId    String?
  durationSeconds Int?
  homeKills       Int?
  awayKills       Int?
  homeGold        Int?
  awayGold        Int?
  mvpName         String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  match      Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winnerTeam Team? @relation("WinnerTeamGames", fields: [winnerTeamId], references: [id])

  @@unique([matchId, gameNumber])
  @@index([matchId])
  @@index([winnerTeamId])
}

enum MatchStage {
  REGULAR_SEASON
  PLAYOFFS
  SEMIFINALS
  FINALS
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
  FORFEIT
  POSTPONED
  CANCELLED
}